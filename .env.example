# Environment variables for ivydunlap.com
# Copy this file to .env and fill in your values.
# In Lovable, add these in Project Settings → Environment Variables.

# ── Mailchimp ────────────────────────────────────────────────────────
# Found at: Mailchimp → Account → Extras → API keys → Create A Key
# Format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us1  (the part after the dash is your datacenter)
MAILCHIMP_API_KEY=

# The Audience ID for your subscriber list.
# Found at: Mailchimp → Audience → Manage Audience → Settings → Audience name and defaults
# Look for "Audience ID" near the bottom of the page.
MAILCHIMP_LIST_ID=
